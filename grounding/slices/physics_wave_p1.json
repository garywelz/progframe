    {
      "id": "electromagnetism-wave-function",
      "name": "Electromagnetic Induction (Faraday's Law)",
      "description": "Faraday's law of induction relates a changing magnetic flux through a circuit to an induced electromotive force: the flux is defined as the surface integral of B, and when it changes in time an EMF equal to minus its rate of change drives a current whose direction, set by Lenz's law, opposes the change.",
      "graphType": "decision_flowchart",
      "domainContext": "Classical electromagnetism",
      "keywords": ["electromagnetic induction", "Faraday's law", "magnetic flux", "Lenz's law", "induced EMF"],
      "basis": "source_extraction:electromagnetism-wave-function",
