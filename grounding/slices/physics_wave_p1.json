    {
      "id": "electromagnetism-quantum-computing",
      "name": "Maxwell's Equations to EM Waves",
      "description": "Maxwell's equations predict electromagnetic waves: in a source-free region, taking the curl of Faraday's law and substituting the Ampere-Maxwell law yields a wave equation for the fields; a transverse plane-wave solution propagates at speed c = 1/sqrt(mu*eps) with E, B, and the wavevector mutually perpendicular.",
      "graphType": "decision_flowchart",
      "domainContext": "Classical electromagnetism",
      "keywords": ["Maxwell's equations", "electromagnetic wave", "wave equation", "speed of light", "transverse wave"],
      "basis": "source_extraction:electromagnetism-quantum-computing",
      "sources": [
        {"title": "A dynamical theory of the electromagnetic field", "authors": "Maxwell, J. C.", "journal": "Philosophical Transactions of the Royal Society", "year": "1865", "doi": "10.1098/rstl.1865.0008", "url": "https://doi.org/10.1098/rstl.1865.0008"},
        {"title": "Introduction to Electrodynamics (4th ed.)", "authors": "Griffiths, D. J.", "journal": "Cambridge University Press", "year": "2017", "doi": "10.1017/9781108333511", "url": "https://doi.org/10.1017/9781108333511"}
      ],
