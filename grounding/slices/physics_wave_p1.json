        {"title": "Experimental researches in electricity (First series)", "authors": "Faraday, M.", "journal": "Philosophical Transactions of the Royal Society", "year": "1832", "doi": "10.1098/rstl.1832.0006", "url": "https://doi.org/10.1098/rstl.1832.0006"},
