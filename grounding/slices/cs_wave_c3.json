    {
      "id": "networks-tcp-congestion-control",
      "name": "TCP Congestion Control",
      "description": "TCP congestion control regulates the sending rate via a congestion window: it begins in slow start with exponential growth, switches to linear congestion avoidance at the slow-start threshold, and on loss reacts differently to triple duplicate ACKs (fast retransmit and recovery) versus a timeout (reset window), seeking steady throughput.",
      "graphType": "decision_flowchart",
      "domainContext": "Computer networks",
      "keywords": ["TCP congestion control", "slow start", "congestion avoidance", "fast retransmit", "AIMD"],
      "basis": "source_extraction:networks-tcp-congestion-control",
