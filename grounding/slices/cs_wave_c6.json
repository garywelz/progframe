    {
      "id": "security-authentication-and-authorization",
      "name": "Authentication & Authorization",
      "description": "Access control separates proving identity from granting rights: a user submits credentials that are verified (authentication), and on success a session or token is issued; when a protected resource is later requested, the system checks the subject's permissions (authorization) and grants or denies the specific action.",
      "graphType": "decision_flowchart",
      "domainContext": "Security",
      "keywords": ["authentication", "authorization", "access control", "session token", "permissions"],
      "basis": "source_extraction:security-authentication-and-authorization",
