    {
      "id": "systems-virtual-memory-paging",
      "name": "Virtual Memory Paging",
      "description": "Paging translates a process's virtual address to a physical one: the address splits into a page number and offset, the TLB is consulted, and on a miss the page table is walked; if the page is not resident a page fault traps to the OS, which evicts a victim and loads the page from disk before forming the physical address.",
      "graphType": "decision_flowchart",
      "domainContext": "Operating systems",
      "keywords": ["virtual memory", "paging", "TLB", "page fault", "page replacement"],
      "basis": "source_extraction:systems-virtual-memory-paging",
      "sources": [
        {"title": "Virtual memory", "authors": "Denning, P. J.", "journal": "ACM Computing Surveys", "year": "1970", "doi": "10.1145/356571.356573", "url": "https://doi.org/10.1145/356571.356573"},
