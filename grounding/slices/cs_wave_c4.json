      ],
      "nodes": [
        {"id": "N1", "label": "New feature / behavior", "role": "red", "shape": "process", "detail": "Requirement", "sourceRef": 0},
        {"id": "N2", "label": "Write a failing test", "role": "green", "shape": "process", "detail": "Specify intent", "sourceRef": 0},
