    {
      "id": "software_engineering-continuous-integration-pipeline",
      "name": "Continuous Integration Pipeline",
      "description": "A CI pipeline validates every change automatically: a push triggers checkout and build, and on success the unit and integration test suites run, followed by static analysis; only when all gates pass is the artifact packaged and deployed to staging, while any failure stops the pipeline and notifies the author to fix.",
      "graphType": "decision_flowchart",
      "domainContext": "Software engineering",
      "keywords": ["continuous integration", "build pipeline", "automated testing", "fail fast", "staging deploy"],
      "basis": "source_extraction:software_engineering-continuous-integration-pipeline",
