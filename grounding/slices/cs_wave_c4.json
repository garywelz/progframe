    {
      "id": "software_engineering-neural-network",
      "name": "Test-Driven Development (TDD)",
      "description": "Test-driven development follows a red-green-refactor cycle: write a failing test that specifies desired behavior, confirm it fails, write the minimal code to make it pass, then refactor while keeping all tests green; the loop repeats per behavior, producing tested, well-factored code.",
      "graphType": "cyclic_pathway",
      "domainContext": "Software engineering",
      "keywords": ["test-driven development", "red-green-refactor", "unit test", "minimal implementation", "regression"],
      "basis": "source_extraction:software_engineering-neural-network",
