    {
      "id": "software_engineering-incident-response",
      "name": "Incident Response",
      "description": "Incident response restores service and learns from failures: an alert is triaged and assigned a severity, an incident is declared and responders assembled, the root cause is investigated, a mitigation applied, and service confirmed restored; a blameless postmortem then captures action items so the failure mode is prevented.",
      "graphType": "decision_flowchart",
      "domainContext": "Software engineering / SRE",
      "keywords": ["incident response", "severity triage", "root cause", "mitigation", "postmortem"],
      "basis": "source_extraction:software_engineering-incident-response",
      "sources": [
        {"title": "Site Reliability Engineering: How Google Runs Production Systems", "authors": "Beyer, B.; Jones, C.; Petoff, J.; Murphy, N. R.", "journal": "O'Reilly Media", "year": "2016", "url": "https://sre.google/sre-book/managing-incidents/"},
        {"title": "Blameless PostMortems and a Just Culture", "authors": "Allspaw, J.", "journal": "Code as Craft (Etsy Engineering)", "year": "2012", "url": "https://www.etsy.com/codeascraft/blameless-postmortems/"}
