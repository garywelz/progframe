    {
      "id": "software_engineering-code-review-workflow",
      "name": "Code Review Workflow",
      "description": "Code review gates changes into the main branch: an author opens a pull request that triggers CI, reviewers read the diff in context, and any change requests send the author back to revise; once discussions are resolved and the reviewers approve, the change is merged and integrated.",
      "graphType": "decision_flowchart",
      "domainContext": "Software engineering",
      "keywords": ["code review", "pull request", "modern code review", "approval", "merge"],
      "basis": "source_extraction:software_engineering-code-review-workflow",
