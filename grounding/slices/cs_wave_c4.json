    {
      "id": "software_engineering-requirements-engineering",
      "name": "Requirements Engineering",
      "description": "Requirements engineering turns stakeholder needs into a validated specification: requirements are elicited, analyzed, and classified as functional behavior or non-functional quality attributes; conflicts and ambiguities are negotiated and resolved, the result is validated with stakeholders, and the agreed set is baselined into a specification.",
      "graphType": "decision_flowchart",
      "domainContext": "Software engineering",
      "keywords": ["requirements engineering", "elicitation", "functional requirements", "non-functional", "validation"],
      "basis": "source_extraction:software_engineering-requirements-engineering",
      "sources": [
        {"title": "Requirements engineering: a roadmap", "authors": "Nuseibeh, B.; Easterbrook, S.", "journal": "Proceedings of the Conference on the Future of Software Engineering", "year": "2000", "doi": "10.1145/336512.336523", "url": "https://doi.org/10.1145/336512.336523"},
        {"title": "Software Engineering (10th ed.)", "authors": "Sommerville, I.", "journal": "Pearson", "year": "2015", "url": "https://www.pearson.com/en-us/subject-catalog/p/software-engineering/P200000003258"}
      ],
      "nodes": [
