    {
      "id": "solid_state-nuclear-decay",
      "name": "Electronic Band Structure (Bloch)",
      "description": "Band structure follows from electrons in a periodic crystal potential: Bloch's theorem writes eigenstates as a plane wave times a lattice-periodic function, solving within the first Brillouin zone produces allowed bands separated by gaps at the zone boundaries, and filling states to the Fermi level classifies the solid as metal, semiconductor, or insulator.",
      "graphType": "decision_flowchart",
      "domainContext": "Solid-state physics",
      "keywords": ["band structure", "Bloch's theorem", "Brillouin zone", "band gap", "Fermi level"],
      "basis": "source_extraction:solid_state-nuclear-decay",
      "sources": [
        {"title": "Uber die Quantenmechanik der Elektronen in Kristallgittern", "authors": "Bloch, F.", "journal": "Zeitschrift fur Physik", "year": "1929", "doi": "10.1007/BF01339455", "url": "https://doi.org/10.1007/BF01339455"},
