        {"title": "Correlation between photons in two coherent beams of light", "authors": "Hanbury Brown, R.; Twiss, R. Q.", "journal": "Nature", "year": "1956", "doi": "10.1038/178058a0", "url": "https://doi.org/10.1038/178058a0"},
