    {
      "id": "optics-wave-optics",
      "name": "Wave Optics (Interference & Diffraction)",
      "description": "Wave optics explains interference and diffraction through the Huygens-Fresnel principle: each point on a wavefront emits secondary wavelets whose amplitudes superpose, and the path difference between contributions decides constructive versus destructive interference, producing the characteristic fringe intensity pattern set by wavelength and aperture geometry.",
      "graphType": "decision_flowchart",
      "domainContext": "Physical (wave) optics",
      "keywords": ["wave optics", "interference", "diffraction", "Huygens-Fresnel", "fringe pattern"],
      "basis": "source_extraction:optics-wave-optics",
      "sources": [
        {"title": "The Bakerian Lecture: Experiments and calculations relative to physical optics", "authors": "Young, T.", "journal": "Philosophical Transactions of the Royal Society", "year": "1804", "doi": "10.1098/rstl.1804.0001", "url": "https://doi.org/10.1098/rstl.1804.0001"},
