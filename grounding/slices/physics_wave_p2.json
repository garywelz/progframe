    {
      "id": "optics-geometric-optics",
      "name": "Geometric Optics (Ray Tracing)",
      "description": "Geometric optics treats light as rays governed by reflection and refraction: principal rays are traced through a mirror or lens, the law of reflection or Snell's law sets ray directions, and the thin-lens/mirror equation locates the image, classifying it as real or virtual with a magnification from the object and image distances.",
      "graphType": "decision_flowchart",
      "domainContext": "Ray (geometric) optics",
      "keywords": ["geometric optics", "ray tracing", "Snell's law", "thin-lens equation", "image formation"],
      "basis": "source_extraction:optics-geometric-optics",
