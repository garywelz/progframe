      "id": "thermodynamics_statistical-heat-engine",
      "name": "Carnot Heat Engine",
      "description": "The Carnot engine sets the maximum efficiency of any heat engine: a working substance runs a reversible cycle of isothermal expansion absorbing heat from the hot reservoir, adiabatic expansion, isothermal compression rejecting heat to the cold reservoir, and adiabatic compression, giving efficiency eta = 1 - Tc/Th.",
      "graphType": "cyclic_pathway",
      "domainContext": "Classical thermodynamics",
      "keywords": ["Carnot cycle", "heat engine", "thermal efficiency", "reversible process", "second law"],
      "basis": "source_extraction:thermodynamics_statistical-heat-engine",
