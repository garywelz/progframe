    {
      "id": "theory-animation",
      "name": "NP-Completeness via Reduction",
      "description": "To prove a problem NP-complete one shows it lies in NP and is NP-hard: membership is shown with a polynomial-time verifier, then a known NP-complete problem is reduced to it by a polynomial-time mapping that preserves yes-instances; verifying the reduction's size and correctness completes the proof.",
      "graphType": "decision_flowchart",
      "domainContext": "Complexity theory",
      "keywords": ["NP-completeness", "polynomial reduction", "NP-hard", "verifier", "Cook-Levin"],
      "basis": "source_extraction:theory-animation",
      "sources": [
        {"title": "The complexity of theorem-proving procedures", "authors": "Cook, S. A.", "journal": "ACM Symposium on Theory of Computing (STOC)", "year": "1971", "doi": "10.1145/800157.805047", "url": "https://doi.org/10.1145/800157.805047"},
        {"title": "Reducibility among combinatorial problems", "authors": "Karp, R. M.", "journal": "Complexity of Computer Computations", "year": "1972", "doi": "10.1007/978-1-4684-2001-2_9", "url": "https://doi.org/10.1007/978-1-4684-2001-2_9"}
